{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Luciole ContactCard (GBNF cible)",
  "description": "Pour un serveur llama.cpp dédié au contact (SANS actions.gbnf). Voir docs/plans/ocr-carte-visite-vcf.md.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "full_name": { "type": "string" },
    "first_name": { "type": "string" },
    "last_name": { "type": "string" },
    "company": { "type": "string" },
    "job_title": { "type": "string" },
    "phones": { "type": "array", "items": { "type": "string" } },
    "emails": { "type": "array", "items": { "type": "string" } },
    "website": { "type": "string" },
    "address": { "type": "string" },
    "note": { "type": "string" }
  }
}
